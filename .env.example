# Отдельный Telegram-бот редактор должен быть администратором канала.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@your_channel

# Кнопка под постом ведёт в основной FaceForm.
FACEFORM_BOT_URL=https://t.me/your_faceform_bot?startapp

CHANNEL_NAME=FaceForm | Разбор внешности
CHANNEL_USERNAME=@your_channel

# Для GitHub Actions используйте путь внутри репозитория.
STATE_FILE=data/content-bot-state.json

DRY_RUN=false
SAMPLE_MODE=false
DISABLE_CARD=false
ALLOW_EVERGREEN_FALLBACK=true
MAX_ARTICLE_AGE_DAYS=14
REQUEST_TIMEOUT_MS=15000

# Необязательно: свои RSS/Atom-ленты через запятую или с новой строки.
# По умолчанию используются тематические RSS-поиски новостей.
RSS_FEEDS=
